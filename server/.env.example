# ── Server ──────────────────────────────────────────────────────────────────
# PORT must match the port in SERVER_URL below — keep them in sync.
PORT=7000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/athleteiq

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-min-16-chars
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS controls which browser origins the CORS middleware accepts.
# Add multiple origins as a comma-separated list: http://localhost:5173,https://app.example.com
# Note: CORS_ORIGIN is retained for reference but is NOT used by the CORS middleware.
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ── ML service ───────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8001

# ── Google Sheets export ─────────────────────────────────────────────────────
# Option A: path to a service-account JSON key (relative to server/ directory)
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/service-account-credentials.json
# Option B: paste the entire service-account JSON as a single-line string
GOOGLE_SHEETS_CREDENTIALS_JSON=
# Option C: set GOOGLE_APPLICATION_CREDENTIALS to a file path for ADC
#   (this env var is read directly by the Google Auth library, not through env.ts)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Spreadsheet ID from the sheet URL: …/spreadsheets/d/<SHEET_ID>/edit
# Example: 1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
# Do NOT paste a Google OAuth Client ID here — that is a different credential.
GOOGLE_SHEETS_SPREADSHEET_ID=
# Leave blank to auto-detect the first worksheet tab
GOOGLE_SHEETS_WORKSHEET_NAME=

# ── Google OAuth ("Continue with Google") ────────────────────────────────────
# Authorized redirect URI to register in Google Cloud Console:
#   http://localhost:7000/api/bauth/callback/google   (development)
#   https://your-domain.com/api/bauth/callback/google (production)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── BetterAuth ───────────────────────────────────────────────────────────────
# Must be >= 16 chars. Falls back to JWT_SECRET if omitted, but use a dedicated value.
BETTER_AUTH_SECRET=your-better-auth-secret-min-16-chars

# ── URLs ─────────────────────────────────────────────────────────────────────
# SERVER_URL port must match PORT above.
SERVER_URL=http://localhost:7000
CLIENT_URL=http://localhost:5173

LOG_LEVEL=info

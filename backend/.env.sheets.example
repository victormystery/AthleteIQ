# Google Sheets Integration
# To enable Google Sheets integration, set this to the path of your service account JSON file
# Example: C:\path\to\your\service-account-credentials.json
# Leave empty to disable Google Sheets integration
GOOGLE_SHEETS_CREDENTIALS_PATH=

# Optional: Override spreadsheet ID (default is already set in settings.py)
# GOOGLE_SHEETS_SPREADSHEET_ID=1tT91nRZYuYtJ6EWUa51q1OuzyUPHpox4QVb8TMqa-r0

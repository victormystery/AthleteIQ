# Production Environment Configuration
APP_NAME=Sports Career Recommender API
VERSION=1.0.0
ENVIRONMENT=production
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/career_recommender

# Security - REQUIRED: set real secrets for production
SECRET_KEY=CHANGE_ME_USE_STRONG_SECRET
JWT_SECRET=CHANGE_ME_USE_STRONG_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=["https://yourdomain.com"]

# ML Model
MODEL_PATH=sports_career_recommendation_model.pkl

# Recommendations
TOTAL_RECOMMENDATIONS=6
ML_RECOMMENDATIONS=5

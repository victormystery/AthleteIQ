          "description": "Entry-level coaching qualification covering fundamental coaching skills and session planning.",
          "type": "certification",
          "duration": "2-3 days",
          "cost": "£150-£200",
          "priority": "required",
          "details": [
            "Introduction to coaching methodology",
            "Session planning and delivery",
            "Safeguarding and child protection",
            "Basic first aid requirements"

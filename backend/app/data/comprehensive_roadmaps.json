        },
        {
          "id": "co-6",
          "title": "Gain Practical Coaching Experience",
          "description": "Build coaching hours and experience across different age groups and competitive levels.",
          "type": "experience",
          "duration": "1-3 years",
          "cost": "Free (voluntary)",
          "priority": "required",
          "details": [
            "Volunteer at grassroots club teams",
            "Assist at academy or development centres",
            "Log coaching hours for accreditation",
            "Seek mentorship from experienced coaches"

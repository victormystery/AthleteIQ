          "description": "Professional-level qualification required for coaching at semi-professional and professional levels.",
          "type": "certification",
          "duration": "18+ months",
          "cost": "£1,000-£2,000",
          "priority": "recommended",
          "details": [
            "Advanced tactical periodization",
            "Leadership and team management",
            "Video analysis integration",
            "Creating playing philosophies"
          ],
          "resources": [
            {"name": "FA Advanced Coaching", "url": "https://www.thefa.com", "type": "course"},
            {"name": "UEFA Courses", "url": "https://www.uefa.com", "type": "course"}

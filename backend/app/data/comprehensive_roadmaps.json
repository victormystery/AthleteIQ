  "roadmaps": {
    "professional-athlete": {
      "pathway_slug": "professional-athlete",
      "pathway_title": "Professional Athlete",
      "time_to_entry": "Immediate if qualified",
      "cost_level": "Low",
      "steps": [
        {
          "id": "pa-1",
          "title": "Join a Youth Academy or Development Programme",
          "description": "Enroll in a professional club's youth academy or grassroots development programme to receive structured training.",
          "type": "experience",
          "duration": "2-4 years",
          "cost": "Free - £2,000/year",
          "priority": "required",
          "details": [
            "Attend trials at local professional club academies",
            "Register with grassroots football clubs for competitive experience",
            "Focus on technical skill development and game understanding",
            "Maintain peak physical fitness through structured training"
          ],
          "resources": [
            {"name": "FA Talent Pathway", "url": "https://www.thefa.com", "type": "article"},
            {"name": "Club Academy Trials", "type": "article"}
          ]
        },
        {
          "id": "pa-2",
          "title": "Complete BTEC or A-Level in Sport",
          "description": "Pursue academic qualifications in sport as a backup plan while developing your athletic career.",
          "type": "academic",
          "duration": "2 years",
          "cost": "Free (college)",
          "priority": "recommended",
          "details": [
            "BTEC Level 3 Extended Diploma in Sport",
            "A-Level Physical Education",
            "Provides foundation knowledge in sports science",
            "Valuable backup if professional career doesn't materialize"
          ],
          "resources": [
            {"name": "Local Colleges", "type": "article"},
            {"name": "Sports Academies", "type": "article"}
          ]
        },
        {
          "id": "pa-3",
          "title": "Anti-Doping Education Certification",
          "description": "Complete mandatory anti-doping education required for all professional athletes.",
          "type": "certification",
          "duration": "1 day",
          "cost": "Free",
          "priority": "required",
          "details": [
            "UKAD Clean Sport education modules",
            "Understanding prohibited substances and methods",
            "Therapeutic Use Exemptions (TUE) knowledge",
            "Whereabouts requirements for elite athletes"
          ],
          "resources": [
            {"name": "UKAD Education", "url": "https://www.ukad.org.uk", "type": "course"},
            {"name": "WADA Courses", "url": "https://www.wada-ama.org", "type": "course"}
          ]
        },
        {
          "id": "pa-4",
          "title": "Sports Psychology & Mental Performance Course",
          "description": "Develop mental resilience and performance psychology skills essential for elite competition.",
          "type": "course",
          "duration": "6-12 weeks",
          "cost": "£200-£500",
          "priority": "recommended",
          "details": [
            "Goal setting and visualization techniques",
            "Managing performance anxiety and pressure",
            "Building mental resilience and focus",
            "Recovery and mindset after setbacks"
          ],
          "resources": [
            {"name": "The Sport Psychology Hub", "url": "https://www.sportpsychologyhub.com", "type": "course"},
            {"name": "Mindflick", "url": "https://www.mindflick.com", "type": "course"}
          ]
        },
        {
          "id": "pa-5",
          "title": "Performance Nutrition Course",
          "description": "Learn evidence-based nutrition strategies to fuel elite athletic performance.",
          "type": "course",
          "duration": "4-8 weeks",
          "cost": "£150-£400",
          "priority": "recommended",
          "details": [
            "Macronutrient timing for performance",
            "Hydration strategies for competition",
            "Recovery nutrition protocols",
            "Supplement education and safety"
          ],
          "resources": [
            {"name": "BASES Sport Nutrition", "url": "https://www.bases.org.uk", "type": "course"},
            {"name": "IOC Nutrition Course", "url": "https://www.olympic.org", "type": "course"}
          ]
        },
        {
          "id": "pa-6",
          "title": "Plan Career Transition Strategy",
          "description": "Prepare for life after competitive sport with education and alternative career planning.",
          "type": "skill",
          "duration": "Ongoing",
          "cost": "Free",
          "priority": "recommended",
          "details": [
            "Complete dual career programmes alongside sport",
            "Obtain coaching qualifications as backup",
            "Network with sports industry professionals",
            "Plan financial management for variable income"
          ],
          "resources": [
            {"name": "TASS Dual Career Support", "url": "https://www.tass.gov.uk", "type": "article"},
            {"name": "PFA Career Transition", "url": "https://www.thepfa.com", "type": "article"}
          ]
        }
      ]
    },
    "coaching": {
      "pathway_slug": "coaching",
      "pathway_title": "Coach / Coaching Education",
      "time_to_entry": "6-12 months",
      "cost_level": "Medium",

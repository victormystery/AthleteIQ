            {"name": "University Sports Programmes", "type": "article"}
          ]
        },
        {
          "id": "co-3",
          "title": "FA Level 2 (UEFA C) Coaching Certificate",
          "description": "Develop ability to plan and deliver coaching sessions for players of all ages.",
          "type": "certification",
          "duration": "5-7 days",
          "cost": "£300-£400",
          "priority": "required",
          "details": [
            "Technical and tactical coaching",
            "Age-appropriate session design",
            "Player development principles",
            "Match analysis basics"
          ],
          "resources": [
            {"name": "FA Learning", "url": "https://www.thefa.com", "type": "course"},
            {"name": "County FA Courses", "type": "article"}
          ]
        },
        {
          "id": "co-4",
          "title": "Sports First Aid Certification",
          "description": "Essential first aid qualification for working with athletes in training and match environments.",
          "type": "certification",
          "duration": "1-2 days",
          "cost": "£80-£150",
          "priority": "required",
          "details": [
            "Emergency action planning",
            "Common sports injuries management",
